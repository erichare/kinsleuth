APP_BASE_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-secret

DATABASE_URL=postgres://kinsleuth:kinsleuth@localhost:5432/kinsleuth
DATABASE_POOL_MAX=10
DATABASE_AUTO_MIGRATE=true
KINRESOLVE_GUIDED_RESEARCH_ENABLED=true

# Data-source rollout gates. Partner approval is independent from enablement.
KINRESOLVE_EXPORT_REFRESH_ENABLED=true
KINRESOLVE_DESKTOP_MEDIA_ENABLED=false
# Set true only after approved rights language/legal review; both media gates are required.
KINRESOLVE_MEDIA_LEGAL_REVIEW_APPROVED=false
KINRESOLVE_ANCESTRY_API_ENABLED=false
KINRESOLVE_ANCESTRY_PARTNER_APPROVED=false

# Private archive-namespaced artifact storage: s3 or vercel-blob.
KINRESOLVE_OBJECT_STORAGE_BACKEND=s3
BLOB_READ_WRITE_TOKEN=
CRON_SECRET=

# Server/worker endpoint and browser-reachable presigned-POST endpoint respectively.
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET=kinsleuth
S3_REGION=us-east-1
# Required for the bundled Docker Compose MinIO service. Set unique values before startup.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
# Used by app/worker processes outside Compose when connecting to an S3-compatible service.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Durable job worker controls. Web and worker processes must share storage and database settings.
KINRESOLVE_WORKER_ID=kinresolve-local-worker
KINRESOLVE_WORKER_POLL_INTERVAL_MS=1000
KINRESOLVE_WORKER_LEASE_DURATION_MS=60000
KINRESOLVE_WORKER_MAX_JOBS_PER_RUN=25
KINRESOLVE_WORKER_MAINTENANCE_INTERVAL_MS=900000
KINRESOLVE_WORKER_MAINTENANCE_LIMIT=100

# Optional private clamd scanner used by long-running and scheduled workers.
# A ZIP with any non-GEDCOM file fails closed before review when this is unset.
KINRESOLVE_MALWARE_SCANNER=none
KINRESOLVE_CLAMD_HOST=127.0.0.1
KINRESOLVE_CLAMD_PORT=3310
KINRESOLVE_MALWARE_SCAN_TIMEOUT_MS=30000
# Keep this at or below clamd's StreamMaxLength (24 MiB fits its stock 25 MiB limit).
KINRESOLVE_MALWARE_SCAN_MAX_BYTES=25165824

AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_API_MODE=responses
AI_CHAT_MODEL=gpt-5-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
