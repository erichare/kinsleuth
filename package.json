{
  "name": "kinsleuth",
  "version": "0.18.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "api:openapi:validate": "node --experimental-strip-types scripts/validate-openapi.mjs",
    "beta:legal:validate": "node --experimental-strip-types scripts/validate-beta-legal-documents.mjs",
    "beta:operator": "node --experimental-strip-types scripts/beta-operator.mjs",
    "api:tokens:revoke-all": "node --import tsx scripts/revoke-api-tokens.mjs",
    "beta:alert:test": "node --experimental-strip-types scripts/observability-test-alert.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:db": "node --experimental-strip-types scripts/require-test-database.mjs && vitest run --no-file-parallelism",
    "test:release-upgrade": "node --experimental-strip-types scripts/require-release-upgrade-database.mjs && vitest run tests/release-upgrade.test.ts",
    "test:release-compatibility": "node --experimental-strip-types scripts/require-release-upgrade-database.mjs && vitest run --no-file-parallelism tests/release-compatibility.test.ts",
    "test:identity-e2e": "node --import tsx scripts/identity-browser-canary.ts",
    "test:e2e": "node --import tsx scripts/browser-canary.ts disposable",
    "test:staging-smoke": "node --env-file=.vercel/.env.production.local --import tsx scripts/browser-canary.ts staging",
    "test:production-smoke": "node --import tsx scripts/browser-canary.ts production",
    "db:migrate": "node --experimental-strip-types scripts/migrate.mjs",
    "db:migrate:production": "node --experimental-strip-types scripts/migrate-production.mjs",
    "db:migrations:verify-production": "node --experimental-strip-types scripts/verify-production-migrations.mjs",
    "db:runtime-role:attest": "node --experimental-strip-types scripts/attest-runtime-database-role.mjs",
    "db:runtime-role:grant-beta-operations": "node --experimental-strip-types scripts/grant-beta-operations-runtime-role.mjs",
    "db:identity": "node --experimental-strip-types scripts/database-identity.mjs",
    "storage:identity:provision": "node --experimental-strip-types scripts/provision-object-storage-identity.mjs",
    "archive:provision": "node scripts/provision-archive.mjs",
    "archive:rotate-public-demo-fixture": "node --import tsx scripts/rotate-public-demo-fixture-command.ts",
    "migrations:verify": "node --experimental-strip-types scripts/verify-migration-history.mjs",
    "release:validate": "node --experimental-strip-types scripts/validate-release-contract.mjs",
    "vercel:config:validate": "node --experimental-strip-types scripts/validate-vercel-deployment-config.mjs",
    "release:readiness:validate": "node --experimental-strip-types scripts/validate-release-readiness.mjs",
    "release:fence:control": "node --import tsx scripts/release-fence-control.mjs",
    "holding:build": "node scripts/build-static-holding.mjs",
    "holding:verify": "node scripts/verify-static-holding.mjs",
    "demo:verify": "node scripts/verify-fictional-demo.mjs",
    "demo:purge": "node --import tsx scripts/demo-purge.mjs",
    "monitoring:validate": "node scripts/validate-monitor-contract.mjs",
    "test:db:large": "node --experimental-strip-types scripts/require-test-database.mjs && RUN_LARGE_GEDCOM_TEST=true vitest run tests/gedcom-apply.test.ts -t \"larger than 10.5 MB\"",
    "test:db:integration-large": "node --experimental-strip-types scripts/require-test-database.mjs && RUN_LARGE_INTEGRATION_TEST=true vitest run --no-file-parallelism tests/integration-large-refresh.test.ts",
    "test:watch": "vitest",
    "worker": "node scripts/worker.mjs",
    "launch:media:validate": "node scripts/validate-launch-media.mjs",
    "site:dev": "npm --prefix site run dev",
    "site:build": "npm --prefix site run build",
    "site:check": "npm --prefix site run check",
    "site:verify": "npm run launch:media:validate && npm --prefix site run verify"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@aws-sdk/s3-presigned-post": "^3.1087.0",
    "@next/env": "^16.0.0",
    "@vercel/blob": "^2.6.1",
    "better-auth": "^1.6.23",
    "jose": "^6.1.0",
    "lucide-react": "^0.468.0",
    "next": "^16.0.0",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "axe-core": "^4.12.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "mp4box": "2.4.1",
    "playwright": "^1.61.1",
    "sharp": "0.34.5",
    "tsx": "^4.23.1",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
