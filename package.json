{
  "name": "kinsleuth",
  "version": "0.17.4",
  "private": true,
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:db": "node --experimental-strip-types scripts/require-test-database.mjs && vitest run --no-file-parallelism",
    "test:release-upgrade": "node --experimental-strip-types scripts/require-release-upgrade-database.mjs && vitest run tests/release-upgrade.test.ts",
    "db:migrate": "node --experimental-strip-types scripts/migrate.mjs",
    "migrations:verify": "node --experimental-strip-types scripts/verify-migration-history.mjs",
    "demo:verify": "node scripts/verify-fictional-demo.mjs",
    "test:db:large": "node --experimental-strip-types scripts/require-test-database.mjs && RUN_LARGE_GEDCOM_TEST=true vitest run tests/gedcom-apply.test.ts -t \"larger than 10.5 MB\"",
    "test:watch": "vitest",
    "worker": "node scripts/worker.mjs",
    "site:dev": "npm --prefix site run dev",
    "site:build": "npm --prefix site run build",
    "site:check": "npm --prefix site run check",
    "site:verify": "npm --prefix site run verify"
  },
  "dependencies": {
    "@next/env": "^16.0.0",
    "@vercel/blob": "^2.6.1",
    "better-auth": "^1.6.23",
    "jose": "^6.1.0",
    "lucide-react": "^0.468.0",
    "next": "^16.0.0",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "playwright": "^1.61.1",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
