      "severity": "SEV-0",
      "consecutiveFailures": 1
    },
    {
      "id": "unsigned-cron-denial",
      "path": "/api/cron/integration-jobs",
      "method": "GET",
      "credentialEnvironmentVariable": null,
      "intervalSeconds": 900,
      "maximumResponseBytes": 4096,
      "redirectPolicy": "error",
      "expectedStatus": [401],
      "expectedContentType": "application/json",
      "bodyContract": "unsigned-cron-denial-v1",
      "severity": "SEV-0",
      "consecutiveFailures": 1
    },
    {
      "id": "protected-readiness",
      "path": "/api/internal/health",
