{
  "schemaVersion": 1,
  "originEnvironmentVariable": "PRODUCTION_APP_BASE_URL",
  "monitors": [
    {
      "id": "public-json-health",
      "path": "/api/health",
      "method": "GET",
      "credentialEnvironmentVariable": null,
      "intervalSeconds": 60,
      "maximumResponseBytes": 4096,
      "redirectPolicy": "error",
      "expectedStatus": [200],
      "expectedContentType": "application/json",
      "bodyContract": "public-health-v1",
      "severity": "SEV-1",
      "consecutiveFailures": 2
    },
    {
      "id": "login-page",
      "path": "/login",
      "method": "GET",
      "credentialEnvironmentVariable": null,
      "intervalSeconds": 300,
      "maximumResponseBytes": 262144,
      "redirectPolicy": "error",
      "expectedStatus": [200],
      "expectedContentType": "text/html",
      "bodyContract": "private-beta-login-v1",
      "severity": "SEV-1",
      "consecutiveFailures": 2
    },
    {
      "id": "anonymous-app-redirect",
      "path": "/app",
      "method": "GET",
      "credentialEnvironmentVariable": null,
      "intervalSeconds": 300,
      "maximumResponseBytes": 4096,
      "redirectPolicy": "error",
      "expectedStatus": [307],
      "expectedContentType": null,
      "bodyContract": "canonical-login-redirect-v1",
      "severity": "SEV-1",
      "consecutiveFailures": 1
    },
    {
      "id": "anonymous-api-denial",
