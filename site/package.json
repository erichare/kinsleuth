{
  "name": "@kinresolve/marketing",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "openapi:publish": "node scripts/publish-openapi.mjs",
    "predev": "npm run openapi:publish",
    "dev": "next dev",
    "prebuild": "npm run openapi:publish",
    "build": "next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "test:export": "node scripts/check-export.mjs",
    "verify": "npm run check && npm run build && npm run test:export"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native": "npm:typescript@^7.0.2",
    "eslint": "^10.7.0",
    "eslint-config-next": "16.2.10",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
